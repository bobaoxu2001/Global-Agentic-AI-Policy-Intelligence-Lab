# BUILD_PROFILE — fixtures | preview | production (default: production; fail-closed).
#   fixtures:   renders the fictional SPEC §14 fixtures behind the persistent
#               "FIXTURE DATA — ILLUSTRATIVE ONLY" banner. Local dev, tests,
#               screenshots, design review ONLY. Never deployable.
#   preview:    Golden 8 AI-assisted research preview. Non-production only.
#   production: rejects fixture:true records and non-published records and
#               enforces the human publication gate.
BUILD_PROFILE=fixtures

# VERCEL_ENV is supplied by Vercel (preview | production). Do not set it in a
# checked-in env file. VERCEL_ENV=production rejects fixtures and preview.
# DEPLOY_ENV remains supported for non-Vercel deploy systems.
#DEPLOY_ENV=production

# Vercel Preview must set BUILD_PROFILE=preview in Preview environment variables.
# Never deploy the preview profile with `vercel --prod`.

# No secrets are used anywhere in this project. Never commit a real .env.
