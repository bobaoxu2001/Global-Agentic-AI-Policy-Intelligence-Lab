# BUILD_PROFILE — fixtures | production (default: production; fail-closed).
#   fixtures:   renders the fictional SPEC §14 fixtures behind the persistent
#               "FIXTURE DATA — ILLUSTRATIVE ONLY" banner. Local dev, tests,
#               screenshots, design review ONLY. Never deployable.
#   production: rejects fixture:true records and non-published records;
#               enforces full integrity validation. The only deployable profile.
BUILD_PROFILE=fixtures

# DEPLOY_ENV — set to "production" by the deploy environment. The build aborts
# if DEPLOY_ENV=production while BUILD_PROFILE=fixtures (rule 10, CB-4).
#DEPLOY_ENV=production

# No secrets are used anywhere in this project. Never commit a real .env.
